# =============================================================================
# EXPRESS TYPESCRIPT BOILERPLATE - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update the values according to your environment
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
HOST=localhost
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
REQUEST_TIMEOUT=30000
BODY_LIMIT=10mb

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# Required: PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Optional: Database connection settings
DB_MAX_CONNECTIONS=10
DB_TIMEOUT=30000
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY=1000

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_KEY_PREFIX=app:
REDIS_DEFAULT_TTL=3600

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
# Required: JWT secret key (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Optional: JWT settings
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
API_KEY_LENGTH=64
SESSION_TIMEOUT=86400

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=false
# LOG_FILE_PATH=logs/app.log
LOG_MAX_FILES=5
LOG_MAX_SIZE=20m
LOG_ENABLE_JSON=true

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESS=false
RATE_LIMIT_SKIP_FAILED=false
RATE_LIMIT_STANDARD_HEADERS=true
RATE_LIMIT_LEGACY_HEADERS=false

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# 1. DATABASE_URL and JWT_SECRET are required for the application to start
# 2. For production, ensure JWT_SECRET is a strong, randomly generated key
# 3. CORS_ORIGINS should be set to your frontend domains in production
# 4. LOG_ENABLE_FILE should be true in production with appropriate LOG_FILE_PATH
# 5. Adjust rate limiting based on your API usage patterns
# =============================================================================