{
    "name": "express-ts-boilerplate",
    "version": "1.0.0",
    "description": "Production-ready Express.js TypeScript boilerplate for blockchain microservices",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node --max-old-space-size=4096 --max-semi-space-size=64 dist/index.js",
        "dev": "node --max-old-space-size=4096 --max-semi-space-size=64 -r ts-node/register -r tsconfig-paths/register src/index.ts",
        "tracker": "node --max-old-space-size=4096 --max-semi-space-size=64 -r ts-node/register -r tsconfig-paths/register src/tracker.ts",
        "memory:demo": "node --max-old-space-size=4096 --max-semi-space-size=64 -r ts-node/register -r tsconfig-paths/register src/infrastructure/memory/example.ts",
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write src/**/*.ts",
        "format:check": "prettier --check src/**/*.ts",
        "docs:build": "node scripts/build-docs.js",
        "docs:watch": "node scripts/build-docs.js --watch",
        "docs:dev": "npm run docs:build && npm run docs:watch",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:seed": "ts-node prisma/seed.ts",
        "db:reset": "prisma migrate reset --force",
        "db:studio": "prisma studio",
        "populate-metadata": "ts-node -r tsconfig-paths/register scripts/populate-metadata-simple.ts",
        "test-metadata": "ts-node -r tsconfig-paths/register scripts/test-metadata.ts",
        "research-nad-images": "ts-node -r tsconfig-paths/register scripts/research-nad-images.ts",
        "backfill-metadata": "ts-node -r tsconfig-paths/register scripts/backfill-token-metadata.ts",
        "backfill-metadata:dry-run": "ts-node -r tsconfig-paths/register scripts/backfill-token-metadata.ts --dry-run",
        "debug-tx": "ts-node -r tsconfig-paths/register scripts/debug-specific-transaction.ts",
        "metrics": "ts-node -r tsconfig-paths/register scripts/advanced-metrics.ts",
        "metrics-monitor": "ts-node -r tsconfig-paths/register scripts/advanced-metrics.ts",
        "metrics-simple": "ts-node -r tsconfig-paths/register scripts/simple-metrics.ts",
        "verify-production": "ts-node -r tsconfig-paths/register scripts/verify-production-ready.ts",
        "switch-optimized": "ts-node -r tsconfig-paths/register scripts/switch-to-optimized.ts",
        "test-worker-pool": "ts-node -r tsconfig-paths/register scripts/test-worker-pool.ts",
        "verify-worker-pool": "ts-node -r tsconfig-paths/register scripts/verify-worker-pool.ts",
        "apply-partitioning": "ts-node -r tsconfig-paths/register scripts/apply-partitioning.ts",
        "create-partitions": "ts-node -r tsconfig-paths/register scripts/create-partitions.ts",
        "refresh-views": "ts-node -r tsconfig-paths/register scripts/refresh-materialized-views.ts",
        "test-partitioning": "ts-node -r tsconfig-paths/register scripts/test-partitioning.ts"
    },
    "keywords": [
        "express",
        "typescript",
        "boilerplate",
        "microservice",
        "blockchain",
        "prisma",
        "redis"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@prisma/client": "^6.16.3",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "ethers": "^6.15.0",
        "express": "^4.19.2",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.2",
        "joi": "^17.11.0",
        "js-yaml": "^4.1.0",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.16.3",
        "prom-client": "^15.1.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "uuid": "^13.0.0",
        "viem": "^2.21.1",
        "winston": "^3.11.0",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "@types/bcrypt": "^5.0.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^30.0.0",
        "@types/js-yaml": "^4.0.9",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.11.5",
        "@types/pg": "^8.15.5",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.5.12",
        "@typescript-eslint/eslint-plugin": "^6.19.1",
        "@typescript-eslint/parser": "^6.19.1",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "jest": "^30.2.0",
        "nodemon": "^3.0.3",
        "prettier": "^3.2.4",
        "prisma": "^6.16.3",
        "ts-jest": "^29.4.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
