// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Monad commit states enum to avoid typos
enum CommitState {
    proposed
    finalized
    verified
}

// User model for authentication and user management
model User {
    id        String   @id @default(cuid())
    email     String   @unique
    username  String   @unique
    password  String
    firstName String?  @map("first_name")
    lastName  String?  @map("last_name")
    isActive  Boolean  @default(true) @map("is_active")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    apiKeys   ApiKey[]
    userRoles UserRole[]

    @@map("users")
}

// API Key model for API authentication
model ApiKey {
    id          String    @id @default(cuid())
    keyId       String    @unique @map("key_id")
    name        String
    hashedKey   String    @map("hashed_key")
    isActive    Boolean   @default(true) @map("is_active")
    expiresAt   DateTime? @map("expires_at")
    lastUsedAt  DateTime? @map("last_used_at")
    permissions Json      @default("[]")
    rateLimit   Json      @default("{}") @map("rate_limit")
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt @map("updated_at")

    // Relations
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("api_keys")
}

// User roles model for many-to-many relationship
model UserRole {
    id        String   @id @default(cuid())
    userId    String   @map("user_id")
    role      String
    createdAt DateTime @default(now()) @map("created_at")

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, role])
    @@map("user_roles")
}

// =============================================================================
// MONAD BLOCKCHAIN TRACKER MODELS
// =============================================================================
// These models mirror the pump.fun structure for frontend compatibility
// while handling Monad-specific features like 4-reserve bonding curves

// Monad equivalent of LaunchedToken
model MonadLaunchedToken {
  id             Int                      @id @default(autoincrement())
  platform       String                  @default("monad") // Always "monad" for this tracker
  signature      String                   @unique // Transaction hash
  creator        String                   // Token creator address
  token          String                   @unique // Token contract address
  bondingCurve   String                   @map("bonding_curve") // Bonding curve contract
  blockNumber    String                   @map("block_number") // Monad block number
  blockId        String                   @map("block_id") // Monad-specific block ID
  commitState    CommitState              @map("commit_state") // proposed/finalized/verified
  timestamp      DateTime
  name           String?                  // Token name (from metadata)
  symbol         String?                  // Token symbol (from metadata)
  metadataId     Int?                     @unique @map("metadata_id")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  // Relations
  archivedTrades ArchivedMonadTokenTrade[]
  metadata       MonadTokenMetadata?      @relation(fields: [metadataId], references: [id])
  tokenStats     MonadTokenTradeStats?
  trades         MonadTokenTrade[]

  @@index([creator])
  @@index([timestamp])
  @@index([signature])
  @@index([token])
  @@index([bondingCurve])
  @@index([platform])
  @@index([blockNumber])
  @@index([commitState])
  @@map("monad_launched_tokens")
}

// Monad equivalent of TokenMetadata
model MonadTokenMetadata {
  id          Int                  @id @default(autoincrement())
  name        String
  symbol      String
  description String?
  image       String?
  showName    Boolean?             @default(false) @map("show_name")
  createdOn   String?              @map("created_on")
  website     Json?
  telegram    String?
  twitter     String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  // Relations
  token       MonadLaunchedToken?

  @@index([name])
  @@index([symbol])
  @@map("monad_token_metadata")
}

// Monad equivalent of TokenTrade
model MonadTokenTrade {
  id                   Int                @id @default(autoincrement())
  tokenAddress         String             @map("token_address")
  signature            String?            // Transaction hash
  blockNumber          String             @map("block_number")
  blockId              String             @map("block_id")
  commitState          CommitState        @map("commit_state") // Track which phase this trade was recorded in
  trader               String
  isBuy                Boolean            @map("is_buy")
  
  // Monad uses WMON (wrapped MON) instead of SOL - store human 18-decimal values
  wmonAmount           Decimal            @map("wmon_amount") @db.Decimal(38, 18)     // WMON (human, 18)
  tokenAmount          Decimal            @map("token_amount") @db.Decimal(38, 18)    // TOK (human, 18)
  pricePerToken        Decimal            @map("price_per_token") @db.Decimal(38, 18) // MON per TOK (human)
  usdAmount            Decimal            @map("usd_amount") @db.Decimal(30, 2)       // USD amounts
  
  isCreatorTrade       Boolean            @default(false) @map("is_creator_trade")
  timestamp            DateTime
  curveProgress        Float?             @map("curve_progress")
  marketCap            Decimal?           @map("market_cap") @db.Decimal(30, 2)       // Market cap in USD
  liquidityUsd         Decimal?           @map("liquidity_usd") @db.Decimal(30, 2)   // Liquidity in USD
  
  // Nad.fun curve reserves (human, 18). **Order matters**:
  // reserve1=realMon, reserve2=realToken, reserve3=virtualMon, reserve4=virtualToken
  reserve1             Decimal?           @db.Decimal(38, 18) // Real MON reserve
  reserve2             Decimal?           @db.Decimal(38, 18) // Real token reserve  
  reserve3             Decimal?           @db.Decimal(38, 18) // Virtual MON reserve
  reserve4             Decimal?           @db.Decimal(38, 18) // Virtual token reserve
  
  usdSpotPrice         Decimal?           @map("usd_spot_price") @db.Decimal(38, 18)  // USD per token
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  token                MonadLaunchedToken @relation(fields: [tokenAddress], references: [token])

  @@index([tokenAddress])
  @@index([trader])
  @@index([timestamp])
  @@index([signature])
  @@index([isCreatorTrade])
  @@index([commitState])
  @@index([blockNumber])
  @@index([tokenAddress, timestamp])
  @@index([trader, timestamp])
  @@index([tokenAddress, commitState]) // For filtering by finalized trades
  @@map("monad_token_trades")
}

// Monad equivalent of TokenTradeStats
model MonadTokenTradeStats {
  id               Int                @id @default(autoincrement())
  tokenAddress     String             @unique @map("token_address")
  totalTxCount     Int                @default(0) @map("total_tx_count")
  totalWmonVolume  Decimal            @default(0) @map("total_wmon_volume") @db.Decimal(38, 18) // WMON volume (human)
  totalUsdVolume   Decimal            @default(0) @map("total_usd_volume") @db.Decimal(30, 2)
  buyCount         Int                @default(0) @map("buy_count")
  sellCount        Int                @default(0) @map("sell_count")
  buyVolumeUsd     Decimal            @default(0) @map("buy_volume_usd") @db.Decimal(30, 2)
  sellVolumeUsd    Decimal            @default(0) @map("sell_volume_usd") @db.Decimal(30, 2)
  creatorHoldings  Decimal            @default(0) @map("creator_holdings") @db.Decimal(38, 18) // Token holdings (human)
  creatorSold      Boolean            @default(false) @map("creator_sold")
  lastTradeTime    DateTime           @map("last_trade_time")
  
  // Monad-specific stats
  proposedTrades   Int                @default(0) @map("proposed_trades")
  finalizedTrades  Int                @default(0) @map("finalized_trades")
  verifiedTrades   Int                @default(0) @map("verified_trades")
  
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  // Relations
  token            MonadLaunchedToken @relation(fields: [tokenAddress], references: [token])

  @@index([tokenAddress])
  @@index([lastTradeTime])
  @@index([totalUsdVolume])
  @@index([creatorSold])
  @@index([finalizedTrades])
  @@map("monad_token_trade_stats")
}

// Monad equivalent of ArchivedTokenTrade
model ArchivedMonadTokenTrade {
  id                   Int                @id @default(autoincrement())
  tokenAddress         String             @map("token_address")
  signature            String?
  blockNumber          String             @map("block_number")
  blockId              String             @map("block_id")
  commitState          CommitState        @map("commit_state")
  trader               String
  isBuy                Boolean            @map("is_buy")
  wmonAmount           Decimal            @map("wmon_amount") @db.Decimal(38, 18)     // WMON (human, 18)
  tokenAmount          Decimal            @map("token_amount") @db.Decimal(38, 18)    // TOK (human, 18)
  pricePerToken        Decimal            @map("price_per_token") @db.Decimal(38, 18) // MON per TOK (human)
  usdAmount            Decimal            @map("usd_amount") @db.Decimal(28, 2)       // USD amounts
  isCreatorTrade       Boolean            @default(false) @map("is_creator_trade")
  timestamp            DateTime
  curveProgress        Float?             @map("curve_progress")
  marketCap            Decimal?           @map("market_cap") @db.Decimal(28, 2)       // Market cap in USD
  reserve1             Decimal?           @db.Decimal(38, 18) // Real MON reserve
  reserve2             Decimal?           @db.Decimal(38, 18) // Real token reserve
  reserve3             Decimal?           @db.Decimal(38, 18) // Virtual MON reserve
  reserve4             Decimal?           @db.Decimal(38, 18) // Virtual token reserve
  usdSpotPrice         Decimal?           @map("usd_spot_price") @db.Decimal(38, 18)  // USD per token
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  token                MonadLaunchedToken @relation(fields: [tokenAddress], references: [token])

  @@index([tokenAddress])
  @@index([trader])
  @@index([timestamp])
  @@index([signature])
  @@index([isCreatorTrade])
  @@index([commitState])
  @@index([tokenAddress, timestamp])
  @@map("archived_monad_token_trades")
}

// Monad equivalent of ArchivedLaunchedToken
model ArchivedMonadLaunchedToken {
  id                Int       @id @default(autoincrement())
  platform          String    @default("monad")
  signature         String
  creator           String
  token             String    @unique
  bondingCurve      String    @map("bonding_curve")
  blockNumber       String    @map("block_number")
  blockId           String    @map("block_id")
  timestamp         DateTime
  name              String?
  symbol            String?
  metadataSnapshot  Json?     @map("metadata_snapshot")
  archivedAt        DateTime  @default(now()) @map("archived_at")
  archiveReason     String    @map("archive_reason")
  lastActivityAt    DateTime? @map("last_activity_at")
  finalMarketCap    Decimal?  @map("final_market_cap") @db.Decimal(20, 2)
  totalVolumeUsd    Decimal?  @default(0) @map("total_volume_usd") @db.Decimal(30, 2)
  totalTrades       Int?      @default(0) @map("total_trades")
  originalCreatedAt DateTime  @map("original_created_at")
  originalUpdatedAt DateTime  @map("original_updated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([token])
  @@index([creator])
  @@index([archivedAt])
  @@index([archiveReason])
  @@index([lastActivityAt])
  @@index([platform])
  @@index([totalVolumeUsd])
  @@index([blockNumber])
  @@map("archived_monad_launched_tokens")
}